{
  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2_1-T2V-1_3B_fp8_e4m3fn.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn",
      "load_device": "offload_device",
      "attention_mode": "sdpa"
    }
  },
  "2": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "fp8_e4m3fn"
    }
  },
  "3": {
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Wan Positive/Negative Prompt" },
    "inputs": {
      "positive_prompt": "A clean educational product video showing a suction plate mechanism, underside shallow suction cup, smooth silicone rim sealing to a tabletop, soft studio lighting, no text, no watermark.",
      "negative_prompt": "text, watermark, subtitles, distorted product, random objects, people, faces, hands, low quality, blurry, flicker",
      "t5": ["2", 0],
      "force_offload": true,
      "model_to_offload": ["1", 0],
      "use_disk_cache": true,
      "device": "gpu"
    }
  },
  "4": {
    "class_type": "WanVideoEmptyEmbeds",
    "inputs": {
      "width": 832,
      "height": 480,
      "num_frames": 33
    }
  },
  "5": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "image_embeds": ["4", 0],
      "text_embeds": ["3", 0],
      "steps": 12,
      "cfg": 4.5,
      "shift": 5.0,
      "seed": 123456789,
      "force_offload": true,
      "scheduler": "unipc",
      "riflex_freq_index": 0
    }
  },
  "6": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "bf16",
      "use_cpu_cache": true,
      "verbose": false
    }
  },
  "7": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["6", 0],
      "samples": ["5", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "8": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["7", 0],
      "frame_rate": 8,
      "loop_count": 0,
      "filename_prefix": "COMFYBranch/wan_t2v",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}